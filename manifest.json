{
  "id": "HN4x8k2m9Qpd",
  "alias": "hackernews",
  "name": "Hacker News Plugin for SocialGata",
  "version": "1.2.1",
  "description": "Browse Hacker News feeds, comments, and search stories",
  "script": "dist/index.js",
  "updateUrl": "https://cdn.jsdelivr.net/gh/InfoGata/hackernews-socialgata@latest/manifest.json",
  "homepage": "https://github.com/InfoGata/hackernews-socialgata",
  "siteMatch": [
    "https://news.ycombinator.com/*"
  ],
  "redirects": [
    {
      "pattern": "https://news.ycombinator.com/item?id=:postId([^&]+){&*}?",
      "path": "/post/:postId"
    },
    {
      "pattern": "https://news.ycombinator.com/user?id=:userId([^&]+){&*}?",
      "path": "/user/:userId"
    }
  ]
}
